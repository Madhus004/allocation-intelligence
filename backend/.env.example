# App
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_REVIEW=gpt-4o-mini
OPENAI_MODEL_FINAL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Frontend origin for CORS
FRONTEND_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=sqlite:///./data/oms_profit_review.db

# Optional: for Postgres/Supabase migrations later
DIRECT_URL=

# RAG / policy retrieval
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIR=./data/chroma_policy_db

# Optional: for Supabase vector retrieval later
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_VECTOR_TABLE=policy_chunks